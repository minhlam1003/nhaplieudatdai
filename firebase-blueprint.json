{
  "entities": {
    "User": {
      "title": "Người dùng hệ thống",
      "description": "Thông tin tài khoản và phân quyền người dùng",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Địa chỉ email của người dùng"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "employee", "viewer"],
          "description": "Vai trò trong hệ thống"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "active", "suspended"],
          "description": "Trạng thái tài khoản"
        }
      },
      "required": ["email", "role", "status"]
    },
    "LandRecord": {
      "title": "Hồ sơ đất đai",
      "description": "Dữ liệu chi tiết về hồ sơ địa chính",
      "type": "object",
      "properties": {
        "maDinhDanh": { "type": "string" },
        "maHoSoLuuTru": { "type": "string" },
        "nhanDe": { "type": "string" },
        "hoTenChuSuDung": { "type": "string" },
        "soGiayChungNhan": { "type": "string" },
        "assignedUid": { 
          "type": "string", 
          "description": "UID của nhân viên được giao phụ trách hồ sơ này" 
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Dữ liệu người dùng"
    },
    "/records/{recordId}": {
      "schema": "LandRecord",
      "description": "Dữ liệu hồ sơ đất đai"
    }
  }
}
