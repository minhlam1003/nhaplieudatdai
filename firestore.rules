rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'lamxtrai2k1@gmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return (data.email == null || (data.email is string && data.email.size() <= 255)) &&
             data.role in ['admin', 'employee', 'viewer', 'pending'] &&
             data.status in ['active', 'pending', 'suspended'];
    }

    function isValidRecord(data) {
      // Maximum flexibility for Excel imports
      return true;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && (
        // Case 1: Self-bootstrapping
        (userId == request.auth.uid && (
          request.auth.token.email == 'lamxtrai2k1@gmail.com' ||
          (incoming().username == 'admin' && incoming().role == 'admin') ||
          incoming().role == 'pending'
        )) ||
        // Case 2: Admin creates user
        isAdmin()
      ) && isValidUser(incoming());
                       
      allow update: if isAdmin() || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['password']));
      allow delete: if isAdmin();
    }

    match /records/{recordId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.assignedUid == request.auth.uid);
      
      allow create: if isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employee')
      );
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource.data.assignedUid == request.auth.uid)
      );
      
      allow delete: if isAdmin();
    }
  }
}
